# Oz AI — Environment Configuration
# Copy this file to .env and adjust values as needed.
# Docker Compose uses the values defined in docker-compose.yml by default.

# Application identity
APP_NAME=Oz AI
APP_VERSION=0.1.0

# Backend server binding (local development)
HOST=0.0.0.0
PORT=8000

# Database connection string
# Local default: SQLite file in the backend working directory
# Docker default: sqlite:////app/data/oz_ai.db (see docker-compose.yml)
DATABASE_URL=sqlite:///./oz_ai.db

# Directory for uploaded log files (relative to repo root locally, /app in Docker)
UPLOAD_DIR=storage/uploads

# Maximum upload size in bytes (default: 50 MB)
MAX_UPLOAD_SIZE_BYTES=52428800

# Frontend API base URL (used by Vite at build/dev time)
VITE_API_URL=http://localhost:8000

# Google Gemini API key (required for LLM agent execution in later sprints)
GOOGLE_API_KEY=

# Gemini model name for ADK agents
GOOGLE_MODEL=gemini-2.5-pro

# ADK application identifier
ADK_APP_NAME=oz_ai

# Enable ADK OpenTelemetry tracing (true/false)
ADK_ENABLE_TRACING=false
